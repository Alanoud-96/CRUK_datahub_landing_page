    "multi_site_or_overlap_mappings": {
        "PCPG": {
        "description": "Pheochromocytoma and paraganglioma are mapped by histology alone because they arise at both adrenal (pheochromocytoma, 8700/3) and extra-adrenal sites (paraganglioma, 8680/3). Using topography to distinguish them is unreliable across registries, so histology is the sole discriminator.",
        "rules": [
