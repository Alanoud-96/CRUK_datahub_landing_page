    "histology_driven_mappings": {
        "LAML": {
        "description": "Acute myeloid leukaemia is mapped by histology alone (9861/3). Topography is not used because AML is a haematological malignancy with no meaningful solid organ site. Other myeloid neoplasms such as CML (9875/3) are intentionally excluded.",
        "rules": [
            {
            "rule_name": "aml_exact",
            "match_type": "histology_exact",
            "histology_codes": [
                "9861/3"
            ],
            "cruk": [
                "Acute myeloid leukaemia (AML)"
            ],
            "tcga": [
                "LAML (Acute Myeloid Leukemia)"
            ]
            }
        ],
        "fallback": {
            "cruk": [
            "Leukaemia"
