{
    "schema_version": "1.1.2",
    "schema_name": "schema_rare_1.1.2",
    "schema_type": "rare_mapping",
    "description": "Schema for rare named CRUK cancer labels using topography-based, histology-based, combined topography-and-histology, direct CRUK label, and fallback mapping rules.",
    "rule_groups": {
        "group_1": "Topography-based rare cancers",
        "group_2": "Histology-based rare cancers",
        "group_3": "Combined topography and histology rare cancers",
        "group_4": "Direct CRUK label rare mappings",
        "group_5": "Fallback rare cancer rule"
    },
    "rare_rules": [

        {
            "rule_name": "ampullary_cancer_by_topography",
            "rule_group": "Topography-based rare cancers",
            "match_type": "topography_exact",
            "topography_exact": [
                "C24.1 Ampulla of Vater"
            ],
            "return_CRUK": ["Ampullary cancer"]
        },
        {
            "rule_name": "eye_cancer_by_topography",
            "rule_group": "Topography-based rare cancers",
            "match_type": "topography_exact",
            "topography_exact": [
                "C69 Eye and adnexa",
                "C69.0 Conjunctiva",
                "C69.1 Cornea, NOS",
                "C69.2 Retina",
                "C69.3 Choroid",
                "C69.4 Ciliary body",
                "C69.5 Lacrimal gland",
                "C69.6 Orbit, NOS",
                "C69.9 Eye, NOS"
            ],
            "return_CRUK": ["Eye cancer"]
        },

        {
            "rule_name": "retinoblastoma_by_histology",
            "rule_group": "Histology-based rare cancers",
            "match_type": "histology_exact",
            "histology_exact": [
                "9510/3 Retinoblastoma, NOS"
            ],
            "return_CRUK": ["Retinoblastoma"]
        },
