            "match_type": "cruk_label",
            "cruk_label": "Ampullary cancer",
            "return_CRUK": ["Ampullary cancer"]
        },
        {
            "rule_name": "gist_direct",
            "rule_group": "Direct CRUK label rare mappings",
            "match_type": "cruk_label",
